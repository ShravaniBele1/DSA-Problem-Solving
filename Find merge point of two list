import java.io.*;
import java.util.*;

class SinglyLinkedListNode{
    int data;
    SinglyLinkedListNode next;
    
    SinglyLinkedListNode(int data){
        this.data = data;
        this.next = null;    
    }
}

public class Solution{
    static int findMergeNode(SinglyLinkedListNode head1, SinglyLinkedListNode head2){
        SinglyLinkedListNode p1 = head1;
        SinglyLinkedListNode p2 = head2;
        
        while(p1 != p2){
            p1 = (p1 == null)? head2 : p1.next;
            p2 = (p2 == null)? head1 : p2.next;
        }
        return p1.data;
    }

    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        
        int t = sc.nextInt();
        
        while(t-- >0){
            
            int index = sc.nextInt();
            
            int n1 = sc.nextInt();
            SinglyLinkedListNode head1=null, tail1=null;
            
            for(int i=0 ;i<n1 ;i++){
                int val= sc.nextInt();
                SinglyLinkedListNode node = new SinglyLinkedListNode(val);
                
                if(head1 == null){
                    head1 = node;
                    tail1 = node;
                }
                else{
                    tail1.next = node;
                    tail1 = node;
                }
            }
            
            int n2 = sc.nextInt();
            SinglyLinkedListNode head2=null, tail2=null;
            
            for(int i=0 ;i<n2 ;i++){
                int val= sc.nextInt();
                SinglyLinkedListNode node = new SinglyLinkedListNode(val);
                
                if(head2 == null){
                    head2 = node;
                    tail2 = node;
                }
                else{
                    tail2.next = node;
                    tail2 = node;
                }
            }
            
        SinglyLinkedListNode mergeNode = head1;
        for(int i=0;i<index;i++)
        {
            mergeNode = mergeNode.next;
        }
        
        tail2.next = mergeNode;

            // call function
            System.out.println(findMergeNode(head1, head2));
        }

        sc.close();
        }
        
 }
    

